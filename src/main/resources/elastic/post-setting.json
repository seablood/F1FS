{
  "analysis": {
    "tokenizer": {
      "kor_autocomplete_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20,
        "token_chars": ["letter"]
      },
      "eng_autocomplete_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 2,
        "max_gram": 20,
        "token_chars": ["letter"]
      },
      "ngram_tokenizer": {
        "type": "ngram",
        "min_gram": 2,
        "max_gram": 3,
        "token_chars": ["letter", "digit"]
      }
    },
    "analyzer": {
      "kor_autocomplete_analyzer": {
        "type": "custom",
        "tokenizer": "kor_autocomplete_tokenizer",
        "filter": ["lowercase"]
      },
      "eng_autocomplete_analyzer": {
        "type": "custom",
        "tokenizer": "eng_autocomplete_tokenizer",
        "filter": ["lowercase"]
      },
      "nori_search": {
        "type": "custom",
        "tokenizer": "nori_tokenizer",
        "filter": ["lowercase", "nori_filter"]
      },
      "ngram_analyzer": {
        "type": "custom",
        "tokenizer": "ngram_tokenizer",
        "filter": ["lowercase"]
      }
    },
    "normalizer": {
      "lowercase_normalizer": {
        "type": "custom",
        "filter": ["lowercase"]
      }
    },
    "filter": {
      "nori_filter": {
        "type": "nori_part_of_speech",
        "stoptags": [
          "E", "IC", "J", "MAG", "MAJ", "MM",
          "SP", "SSC", "SSO", "SC", "SE",
          "XPN", "XSA", "XSN", "XSV", "UNA", "NA", "VSV"
        ]
      }
    }
  }
}